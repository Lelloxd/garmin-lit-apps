{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Golf Range (Windows)",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Golf Range (macOS/Linux)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/build.sh"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [],
            "isBackground": false
        },
        {
            "label": "Open Documentation",
            "type": "shell",
            "command": "start",
            "args": [
                "${workspaceFolder}/README.md"
            ],
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        }
    ]
}
